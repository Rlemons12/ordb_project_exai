# =========================
# Oracle Database Connection (Logical)
# =========================

ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=FREEPDB1
ORACLE_PDB=FREEPDB1

# Application schema/user
# Change these for the target Oracle database.
ORACLE_USER=devuser
ORACLE_PASSWORD=devpass


# =========================
# Oracle Connection Strings
# =========================

# Python python-oracledb / cx_Oracle style
ORACLE_DSN=localhost:1521/FREEPDB1

# JDBC Thin style used by SQLcl, ORDS, and Java tools
ORACLE_JDBC_URL=jdbc:oracle:thin:@//localhost:1521/FREEPDB1


# =========================
# ORDS Configuration
# =========================

ORDS_BASE_URL=http://localhost:8080/ords
ORDS_SCHEMA_PATH=/dev
ORDS_COLOURS_ENDPOINT=/colours


# =========================
# Java / SQLcl
# =========================

JAVA_HOME=C:\java\jdk-17.0.17
SQLCL_JDBC=thin


# =========================
# Environment Marker
# =========================

APP_ENV=local
